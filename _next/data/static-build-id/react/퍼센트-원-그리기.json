/span><span class=\"token unit\">vw</span><span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t<span class=\"token property\">height</span><span class=\"token punctuation\">:</span> <span class=\"token number\">100</span><span class=\"token unit\">vh</span><span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t<span class=\"token property\">justify-content</span><span class=\"token punctuation\">:</span> center<span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t<span class=\"token property\">align-items</span><span class=\"token punctuation\">:</span> center<span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t<span class=\"token selector\"><span class=\"token class\">.circle</span></span> <span class=\"token punctuation\">{</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t\t<span class=\"token property\">width</span><span class=\"token punctuation\">:</span> <span class=\"token number\">320</span><span class=\"token unit\">px</span><span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">\t\t<span class=\"token property\">height</span><span class=\"token punctuation\">:</span> <span class=\"token number\">320</span><span class=\"token unit\">px</span><span class=\"token punctuation\">;</span>\n</span></span></span><span class=\"code-line\"><span class=\"token template-string\"><span class=\"token css language-css\">